library(ggplot2)

eigen_vec <- read.csv("cleaned_qtl_pca.eigenvec")
eigen_val <- read.csv("qtl_pca.eigenval", header = FALSE)
sp <- read.csv("Species.csv")


colnames(eigen_vec) <- c("name2", "PC1", "PC2", "PC3", "PC4", "PC5", "PC6", "PC7", "PC8", "PC9", "PC10")

# Convert eigenvals to percentages
eigen_per <- eigen_val / sum(eigen_val) * 100

# make axis labels
pc1_lab <- paste("PC1 (", round(eigen_per[[1, 1]], 2), "%)", sep = "")
pc2_lab <- paste("PC2 (", round(eigen_per[[2, 1]], 2), "%)", sep = "")

# Make scatterplot by species

ggplot(eigen_vec, aes(x = PC1, y = PC2, color = sp$Species)) +
  geom_point(size = 2.5) + labs(x = pc1_lab, y = pc2_lab) +
  scale_color_manual(
    name = "Species Identity", # Legend title
    values = c(
"c" = "darkgoldenrod1", "g" = "darkslategray3", "l" = "darkorchid2", "n" = "darkgreen", "u" = "red"), 
    labels = c("cupreus", "glabratus", "luteus", "nasutus", "unknown")) + theme_minimal()
  
# Make scatterplot by geography

ggplot(eigen_vec, aes(x = PC1, y = PC2, color = sp$Region)) +
  geom_point(size = 2.5) + labs(x = pc1_lab, y = pc2_lab)  +
  scale_color_manual(
    name = "Region", # Legend title
    values = c(
      "North" = "aquamarine3", "South" = "salmon1"), 
    labels = c("North", "South")) + theme_minimal()

