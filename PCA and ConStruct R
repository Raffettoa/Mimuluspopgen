colnames(temp) <- c("Lon", "Lat")
geo<-data.matrix(temp)
geo

install.packages('distGeo')
dist <- geosphere::distm(geo)
dist

##running a non-spatial model
Q30_run_20k <- conStruct(spatial = FALSE,
                          K = 2,
                          freqs = freq,
                          geoDist = NULL,
                          coords = geo,
                          n.chains=1,
                          n.iter=20000,
                          prefix = "Q30_run_20k")

#find optimal number of clusters
