# Apply threshold to get binary maps (1 = suitable, 0 = not suitable)
threshold <- 0.3  # adjust based on your model's recommended threshold

lut_current_bin <- ifel(p_lut$General_consensus$mean >= threshold, 1, 0)
cup_current_bin <- ifel(p_cup$General_consensus$mean >= threshold, 1, 0)
lut_lgm_bin    <- ifel(p_lut_lgm$General_consensus$mean >= threshold, 1, 0)
cup_lgm_bin    <- ifel(p_cup_lgm$General_consensus$mean >= threshold, 1, 0)

# Count suitable cells and convert to km2
# At 30 arc-seconds, each cell is approximately 0.86 km2 at 35°S latitude
# Better to compute it properly from the raster
cell_areas <- cellSize(lut_current_bin, unit = "km")

# Suitable area per scenario
lut_current_area <- global(ifel(lut_current_bin == 1, cell_areas, 0), sum, na.rm=TRUE)
lut_lgm_area     <- global(ifel(lut_lgm_bin == 1, cell_areas, 0), sum, na.rm=TRUE)
cup_current_area <- global(ifel(cup_current_bin == 1, cell_areas, 0), sum, na.rm=TRUE)
cup_lgm_area     <- global(ifel(cup_lgm_bin == 1, cell_areas, 0), sum, na.rm=TRUE)

# Percent change
lut_change <- (lut_current_area - lut_lgm_area) / lut_lgm_area * 100
cup_change <- (cup_current_area - cup_lgm_area) / cup_lgm_area * 100

cat("Luteus area change since LGM:", round(lut_change$sum, 1), "%\n")
cat("Cupreus area change since LGM:", round(cup_change$sum, 1), "%\n")

# Cells where both species are suitable
overlap <- ifel(lut_current_bin == 1 & cup_current_bin == 1, 1, 0)
lut_only <- ifel(lut_current_bin == 1 & cup_current_bin == 0, 1, 0)
cup_only <- ifel(lut_current_bin == 0 & cup_current_bin == 1, 1, 0)

overlap_area     <- global(ifel(overlap == 1, cell_areas, 0), sum, na.rm=TRUE)
lut_only_area    <- global(ifel(lut_only == 1, cell_areas, 0), sum, na.rm=TRUE)
cup_only_area    <- global(ifel(cup_only == 1, cell_areas, 0), sum, na.rm=TRUE)

# Schoener's D overlap index (0 = no overlap, 1 = identical)
# This is the proper metric for niche overlap
union_area <- global(ifel(lut_current_bin == 1 | cup_current_bin == 1, cell_areas, 0), sum, na.rm=TRUE)
jaccard <- overlap_area / union_area
cat("Jaccard overlap index:", round(jaccard$sum, 3), "\n")

# Create a categorical change raster for luteus current vs LGM
# 0 = never suitable, 1 = lost since LGM, 2 = gained since LGM, 3 = stable suitable
change_lut <- ifel(lut_lgm_bin == 0 & lut_current_bin == 0, 0,  # never suitable
                   ifel(lut_lgm_bin == 1 & lut_current_bin == 0, 1,  # lost
                        ifel(lut_lgm_bin == 0 & lut_current_bin == 1, 2,  # gained
                             3)))                                           # stable

