# Then automated filtering
filter_correlated <- function(cor_mat, threshold = 0.7) {
  keep <- c()
  drop <- c()
  vars <- colnames(cor_mat)
  
  for (v in vars) {
    if (v %in% drop) next
    keep <- c(keep, v)
    correlated <- names(which(abs(cor_mat[v, ]) >= threshold & names(cor_mat[v,]) != v))
    drop <- c(drop, correlated)
  }
  return(keep)
}

