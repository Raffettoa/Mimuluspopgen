# ─── ANNOTATE CANDIDATE WINDOWS ──────────────────────────────────────────────

label_windows <- function(df, cands, chrom_col = "chromosome") {
  df$in_candidate    <- FALSE
  df$candidate_region <- NA_character_
  for (i in seq_len(nrow(cands))) {
    hit <- df[[chrom_col]] == cands$chrom[i] &
      df$window_pos_1  <  cands$end[i]  &
      df$window_pos_2  >  cands$start[i]
    df$in_candidate[hit]     <- TRUE
    df$candidate_region[hit] <- cands$region_name[i]
  }
  df
}

