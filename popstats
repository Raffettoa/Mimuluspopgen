# =============================================================================
# Genome-wide population statistics from pixy output -- by region
# ---------------------------------------------------------------------------
# Expects this layout, with the script sitting alongside wganalysis/:
#
#   ./
#   |-- pixy_popstats_by_region.R      <- this script
#   |-- wganalysis/
#       |-- north_pixy/    pixy_pi.txt  pixy_dxy.txt  pixy_fst.txt
#       |-- central_pixy/  pixy_pi.txt  pixy_dxy.txt  pixy_fst.txt
#       |-- south_pixy/    pixy_pi.txt  pixy_dxy.txt  pixy_fst.txt
#
# Each folder holds a cupreus (C) vs luteus (L) comparison for that region.
# Everything is stacked into one long table with a `region` column, so the
# headline contrast (north vs south C-vs-L divergence) falls straight out.
# =============================================================================

library(tidyverse)

# --- SETTINGS ----------------------------------------------------------------

BASE_DIR <- "wganalysis"          # folder holding the *_pixy subfolders

# Region folder -> display label. Order here sets the order in every figure.
REGIONS <- c(north_pixy   = "North",
             central_pixy = "Central",
             south_pixy   = "South")

# Map the pixy `pop` labels to display names. Left side must match your
# pixy populations file exactly.
POP_LABELS <- c(C = "cupreus", L = "luteus")

WINDOW_SIZE <- 5000               # window size used in the pixy run (labels only)

MIN_SITES <- 500                  # min callable sites for a Pi / Dxy window
MIN_SNPS  <- 5                    # min SNPs for an Fst window

N_BOOT <- 1000                    # bootstrap replicates for CIs

OUTDIR <- "pop_stats_summary"
dir.create(OUTDIR, showWarnings = FALSE)
set.seed(42)


# --- LOAD ALL REGIONS --------------------------------------------------------
# read_region() reads one pixy file from one region folder and tags it.

read_region <- function(folder, label, filename) {
  path <- file.path(BASE_DIR, folder, filename)
  if (!file.exists(path)) {
    stop("Missing file: ", path,
         "\nCheck BASE_DIR and the REGIONS folder names at the top of the script.")
  }
  read_tsv(path, show_col_types = FALSE) |>
    mutate(region = label, .before = 1)
}

read_all <- function(filename) {
  imap(REGIONS, ~ read_region(.y, .x, filename)) |>
    list_rbind() |>
    mutate(region = factor(region, levels = unname(REGIONS)))
}

# NB: named *_raw so we don't mask R's built-in `pi` constant.
pi_raw  <- read_all("pixy_pi.txt")
dxy_raw <- read_all("pixy_dxy.txt")
fst_raw <- read_all("pixy_fst.txt")

message("Loaded windows per region:")
print(count(pi_raw, region, pop))

# Guard: the count columns are what correct Pi/Dxy aggregation depends on
if (!all(c("count_diffs", "count_comparisons") %in% names(pi_raw))) {
  stop("count_diffs / count_comparisons not found in pixy_pi.txt. ",
       "Genome-wide Pi/Dxy cannot be computed correctly without them.")
}


# --- BOOTSTRAP HELPERS (resample windows with replacement) -------------------

boot_ratio <- function(diffs, comps, n = N_BOOT) {
  k <- length(diffs)
  reps <- replicate(n, {
    i <- sample.int(k, k, replace = TRUE)
    sum(diffs[i]) / sum(comps[i])
  })
  quantile(reps, c(0.025, 0.975), na.rm = TRUE)
}

boot_wmean <- function(x, w, n = N_BOOT) {
  k <- length(x)
  reps <- replicate(n, {
    i <- sample.int(k, k, replace = TRUE)
    weighted.mean(x[i], w[i], na.rm = TRUE)
  })
  quantile(reps, c(0.025, 0.975), na.rm = TRUE)
}


# --- PI: per species, per region ---------------------------------------------
# Genome-wide Pi is sum(count_diffs)/sum(count_comparisons), NOT mean(avg_pi).
# Averaging per-window ratios overweights sparse windows and biases the value.

pi_f <- pi_raw |> filter(no_sites >= MIN_SITES)

pi_summary <- pi_f |>
  group_by(region, pop) |>
  summarize(
    n_windows      = n(),
    total_diffs    = sum(count_diffs,       na.rm = TRUE),
    total_comps    = sum(count_comparisons, na.rm = TRUE),
    pi             = total_diffs / total_comps,
    pi_window_mean = mean(avg_pi, na.rm = TRUE),   # for comparison only
    .groups = "drop"
  )

pi_ci <- pi_f |>
  group_by(region, pop) |>
  group_modify(~ {
    ci <- boot_ratio(.x$count_diffs, .x$count_comparisons)
    tibble(ci95_lo = ci[[1]], ci95_hi = ci[[2]])
  }) |>
  ungroup()

pi_summary <- left_join(pi_summary, pi_ci, by = c("region", "pop")) |>
  mutate(species = recode(pop, !!!POP_LABELS))


# --- DXY: C vs L, per region -------------------------------------------------

dxy_f <- dxy_raw |> filter(no_sites >= MIN_SITES)

dxy_summary <- dxy_f |>
  group_by(region, pop1, pop2) |>
  summarize(
    n_windows       = n(),
    total_diffs     = sum(count_diffs,       na.rm = TRUE),
    total_comps     = sum(count_comparisons, na.rm = TRUE),
    dxy             = total_diffs / total_comps,
    dxy_window_mean = mean(avg_dxy, na.rm = TRUE),
    .groups = "drop"
  )

dxy_ci <- dxy_f |>
  group_by(region, pop1, pop2) |>
  group_modify(~ {
    ci <- boot_ratio(.x$count_diffs, .x$count_comparisons)
    tibble(ci95_lo = ci[[1]], ci95_hi = ci[[2]])
  }) |>
  ungroup()

dxy_summary <- left_join(dxy_summary, dxy_ci, by = c("region", "pop1", "pop2"))


# --- FST: C vs L, per region -------------------------------------------------
# Fst is a ratio of variance components, so it can't be aggregated by summing
# counts the way Pi/Dxy can. With standard pixy output the most defensible
# summary is a SNP-weighted mean; plain mean and median are reported alongside.
# Negative per-window WC Fst is normal at low differentiation -- not clamped.

fst_f <- fst_raw |> filter(!is.na(avg_wc_fst), no_snps >= MIN_SNPS)

fst_summary <- fst_f |>
  group_by(region, pop1, pop2) |>
  summarize(
    n_windows    = n(),
    total_snps   = sum(no_snps, na.rm = TRUE),
    fst_weighted = weighted.mean(avg_wc_fst, w = no_snps, na.rm = TRUE),
    fst_mean     = mean(avg_wc_fst,   na.rm = TRUE),
    fst_median   = median(avg_wc_fst, na.rm = TRUE),
    .groups = "drop"
  )

fst_ci <- fst_f |>
  group_by(region, pop1, pop2) |>
  group_modify(~ {
    ci <- boot_wmean(.x$avg_wc_fst, .x$no_snps)
    tibble(ci95_lo = ci[[1]], ci95_hi = ci[[2]])
  }) |>
  ungroup()

fst_summary <- left_join(fst_summary, fst_ci, by = c("region", "pop1", "pop2"))


# --- PRINT + WRITE TABLES ----------------------------------------------------

message("\n=== Pi (per species, per region) ===")
print(pi_summary |> select(region, species, n_windows, pi, ci95_lo, ci95_hi,
                           pi_window_mean), n = Inf)

message("\n=== Dxy (cupreus vs luteus, per region) ===")
print(dxy_summary |> select(region, n_windows, dxy, ci95_lo, ci95_hi,
                            dxy_window_mean), n = Inf)

message("\n=== Fst (cupreus vs luteus, per region) ===")
print(fst_summary |> select(region, n_windows, fst_weighted, ci95_lo, ci95_hi,
                            fst_mean, fst_median), n = Inf)

write_tsv(pi_summary,  file.path(OUTDIR, "pi_summary_by_region.tsv"))
write_tsv(dxy_summary, file.path(OUTDIR, "dxy_summary_by_region.tsv"))
write_tsv(fst_summary, file.path(OUTDIR, "fst_summary_by_region.tsv"))

# One tidy table ready to drop into the manuscript
manuscript_table <- bind_rows(
  pi_summary |> transmute(region, statistic = paste0("Pi (", species, ")"),
                          estimate = pi, ci95_lo, ci95_hi, n_windows),
  dxy_summary |> transmute(region, statistic = "Dxy (C vs L)",
                           estimate = dxy, ci95_lo, ci95_hi, n_windows),
  fst_summary |> transmute(region, statistic = "Fst (C vs L)",
                           estimate = fst_weighted, ci95_lo, ci95_hi, n_windows)
) |>
  arrange(region, statistic) |>
  mutate(across(c(estimate, ci95_lo, ci95_hi), ~ signif(.x, 3)))

message("\n=== Manuscript table ===")
print(manuscript_table, n = Inf)
write_tsv(manuscript_table, file.path(OUTDIR, "manuscript_table.tsv"))


# --- PLOT 1: the headline figure -- Dxy and Fst by region --------------------

pair_stats <- bind_rows(
  dxy_summary |> transmute(region, statistic = "D[XY]",
                           estimate = dxy, ci95_lo, ci95_hi),
  fst_summary |> transmute(region, statistic = "F[ST]",
                           estimate = fst_weighted, ci95_lo, ci95_hi)
)

p_pairs <- ggplot(pair_stats, aes(x = region, y = estimate)) +
  geom_pointrange(aes(ymin = ci95_lo, ymax = ci95_hi),
                  linewidth = 0.7, size = 0.6, colour = "grey15") +
  facet_wrap(~ statistic, scales = "free_y", labeller = label_parsed) +
  labs(x = NULL, y = "Estimate (95% CI)",
       title = "Cupreus vs luteus divergence by region") +
  theme_bw(base_size = 12) +
  theme(panel.grid.minor = element_blank(),
        strip.background = element_rect(fill = "grey95", colour = NA))

ggsave(file.path(OUTDIR, "divergence_by_region.pdf"), p_pairs,
       width = 7, height = 3.5)


# --- PLOT 2: per-window Fst distributions by region --------------------------
# Shows the spread behind each mean -- makes the north/south contrast concrete.

p_fst_dist <- ggplot(fst_f, aes(x = region, y = avg_wc_fst)) +
  geom_violin(fill = "grey85", colour = NA, scale = "width") +
  geom_boxplot(width = 0.12, outlier.size = 0.2, outlier.alpha = 0.3,
               fill = "white") +
  geom_hline(yintercept = 0, linetype = "dashed", colour = "grey50",
             linewidth = 0.3) +
  labs(x = NULL,
       y = bquote(F[ST]~"(per "*.(WINDOW_SIZE/1000)*" kb window)"),
       title = "Per-window cupreus vs luteus Fst by region") +
  theme_bw(base_size = 12) +
  theme(panel.grid.minor = element_blank())

ggsave(file.path(OUTDIR, "fst_windows_by_region.pdf"), p_fst_dist,
       width = 6, height = 4)


# --- PLOT 3: Pi per species, per region --------------------------------------

p_pi <- ggplot(pi_summary, aes(x = region, y = pi, fill = species)) +
  geom_col(position = position_dodge(width = 0.7), width = 0.6,
           colour = "grey30", linewidth = 0.2) +
  geom_errorbar(aes(ymin = ci95_lo, ymax = ci95_hi),
                position = position_dodge(width = 0.7), width = 0.15) +
  scale_fill_manual(values = c(cupreus = "grey35", luteus = "grey75")) +
  labs(x = NULL, y = expression(pi), fill = NULL,
       title = "Nucleotide diversity by species and region") +
  theme_bw(base_size = 12) +
  theme(panel.grid.minor = element_blank(),
        legend.position = "top")

ggsave(file.path(OUTDIR, "pi_by_species_region.pdf"), p_pi,
       width = 6, height = 4)

message("\nDone. Tables + figures written to: ", normalizePath(OUTDIR))
