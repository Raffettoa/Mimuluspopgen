# Manhattan-style plot
manhattan_plot <- function(df, stat_col, y_label, plot_title, raw_df) {
  # Use raw (unfiltered) data for chromosome boundaries
  chrom_info <- raw_df |>
    group_by(chromosome) |>
    summarize(chrom_len = max(window_pos_2), .groups = "drop") |>
    arrange(chromosome) |>
    mutate(offset    = cumsum(lag(chrom_len, default = 0)),
           chrom_mid = offset + chrom_len / 2,
           chrom_idx = row_number())
  
  df_plot <- df |>
    filter(!is.na(.data[[stat_col]])) |>
    left_join(chrom_info |> select(chromosome, offset, chrom_idx), by = "chromosome") |>
    mutate(plot_x = (window_pos_1 + window_pos_2) / 2 + offset)
  
  strips <- chrom_info |>
    mutate(xmin = offset, xmax = offset + chrom_len,
           fill_col = if_else(chrom_idx %% 2 == 0, "white", "grey96"))
  
  ggplot(df_plot, aes(x = plot_x, y = .data[[stat_col]])) +
    geom_rect(data = strips,
              aes(xmin = xmin, xmax = xmax, ymin = -Inf, ymax = Inf, fill = fill_col),
              inherit.aes = FALSE, alpha = 0.6) +
    scale_fill_identity() +
    geom_point(aes(color = in_candidate), size = 0.35, alpha = 0.55) +
    scale_color_manual(values = c("FALSE" = "grey55", "TRUE" = "#C0392B"),
                       labels = c("FALSE" = "Background", "TRUE" = "Candidate"),
                       name = NULL) +
    scale_x_continuous(breaks = chrom_info$chrom_mid, labels = chrom_info$chromosome,
                       expand = expansion(mult = 0.01)) +
    labs(y = y_label, x = NULL, title = plot_title) +
    theme_bw(base_size = 10) +
    theme(axis.text.x = element_text(angle = 55, hjust = 1, size = 7),
          legend.position = "top",
          panel.grid.minor = element_blank(),
          panel.grid.major.x = element_blank())
}


