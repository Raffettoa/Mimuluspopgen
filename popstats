# ─── STATISTICAL TESTS ───────────────────────────────────────────────────────

# 1. Wilcoxon rank-sum test (non-parametric; p-values approximate due to
#    spatial autocorrelation between windows — use permutation for reporting)

message("\n=== Wilcoxon rank-sum tests (approximate) ===")

run_wilcox <- function(df, stat_col, label) {
  cand <- df[[stat_col]][df$in_candidate  & !is.na(df[[stat_col]])]
  bg   <- df[[stat_col]][!df$in_candidate & !is.na(df[[stat_col]])]
  if (length(cand) < 2) { cat(sprintf("  %-18s SKIPPED (too few candidate windows)\n", label)); return() }
  w <- wilcox.test(cand, bg, alternative = "two.sided")
  cat(sprintf("  %-18s W=%.0f  p=%.5f  cand_mean=%.5f  bg_mean=%.5f  n_cand=%d\n",
              label, w$statistic, w$p.value, mean(cand), mean(bg), length(cand)))
}

run_wilcox(fst_f,  "avg_wc_fst", "Fst")
run_wilcox(dxy_f,  "avg_dxy",    "Dxy")
run_wilcox(pi_cup, "avg_pi",     "Pi (cupreus)")
run_wilcox(pi_lut, "avg_pi",     "Pi (luteus)")

# 2. Permutation test — RECOMMENDED for reporting
#
# Null: candidate windows are no different from a random draw of the same
# number of windows from the genome background.
# Avoids the inflated-N problem from spatial autocorrelation by comparing
# means rather than testing window-level independence.
#
# Reports: observed difference in means, p_perm (two-tailed), fold enrichment

perm_test <- function(df, stat_col, n_perm = 10000, seed = 42) {
  set.seed(seed)
  cand_vals <- df[[stat_col]][df$in_candidate  & !is.na(df[[stat_col]])]
  bg_vals   <- df[[stat_col]][!df$in_candidate & !is.na(df[[stat_col]])]
  if (length(cand_vals) < 2 || length(bg_vals) < length(cand_vals)) {
    return(tibble(obs_cand_mean=NA, obs_bg_mean=NA, obs_diff=NA,
                  fold_over_bg=NA, p_perm=NA, n_cand=length(cand_vals), n_bg=length(bg_vals)))
  }
  obs_diff  <- mean(cand_vals) - mean(bg_vals)
  perm_diffs <- replicate(n_perm,
                          mean(sample(bg_vals, length(cand_vals), replace = FALSE)) - mean(bg_vals))
  tibble(
    obs_cand_mean = mean(cand_vals),
    obs_bg_mean   = mean(bg_vals),
    obs_diff      = obs_diff,
    fold_over_bg  = mean(cand_vals) / mean(bg_vals),
    p_perm        = mean(abs(perm_diffs) >= abs(obs_diff)),
    n_cand        = length(cand_vals),
    n_bg          = length(bg_vals)
  )
}

message("\n=== Permutation tests (n=10,000 draws from background; two-tailed) ===")

perm_all <- bind_rows(
  perm_test(fst_f,  "avg_wc_fst") |> mutate(stat = "Fst"),
  perm_test(dxy_f,  "avg_dxy")    |> mutate(stat = "Dxy"),
  perm_test(pi_cup, "avg_pi")     |> mutate(stat = "Pi_cupreus"),
  perm_test(pi_lut, "avg_pi")     |> mutate(stat = "Pi_luteus")
)

print(perm_all |> select(stat, obs_cand_mean, obs_bg_mean, obs_diff, fold_over_bg, p_perm, n_cand, n_bg), n = Inf)
