# ─── SUMMARY STATISTICS ──────────────────────────────────────────────────────

summarize_stat <- function(df, stat_col) {
  df |>
    filter(!is.na(.data[[stat_col]])) |>
    group_by(in_candidate) |>
    summarize(
      region    = if_else(first(in_candidate), "Candidate", "Background"),
      n_windows = n(),
      mean      = mean(.data[[stat_col]]),
      median    = median(.data[[stat_col]]),
      sd        = sd(.data[[stat_col]]),
      se        = sd / sqrt(n_windows),
      ci95_lo   = mean - 1.96 * se,
      ci95_hi   = mean + 1.96 * se,
      .groups   = "drop"
    )
}

summary_all <- bind_rows(
  summarize_stat(fst_f,  "avg_wc_fst") |> mutate(stat = "Fst"),
  summarize_stat(dxy_f,  "avg_dxy")    |> mutate(stat = "Dxy"),
  summarize_stat(pi_cup, "avg_pi")     |> mutate(stat = "Pi_cupreus"),
  summarize_stat(pi_lut, "avg_pi")     |> mutate(stat = "Pi_luteus")
)

