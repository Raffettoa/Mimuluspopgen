# ─── PER-CANDIDATE BREAKDOWN ──────────────────────────────────────────────────

per_region <- function(df, stat_col) {
  df |>
    filter(in_candidate, !is.na(.data[[stat_col]])) |>
    group_by(candidate_region) |>
    summarize(n_windows = n(), mean = mean(.data[[stat_col]]),
              median = median(.data[[stat_col]]), .groups = "drop") |>
    arrange(desc(mean))
}

