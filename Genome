for file in $SAM_FILES/*.sam; do
    start_time=$(date +%s)
    base=${file##*/}
 
    outfile=${base/_R1_001.sam/.bam}
    MAPPED_OUT="$MAPPED_OUTDIR/$outfile"
    sample_name=$(echo "$file" | cut -d"_" -f1)
    
    ## Run samtools view
    cat filter_SAM.sh \
    | sed "s,@@input_sam@@,$file,g" \
    | sed "s,@@MAPPED_OUT@@,$MAPPED_OUT,g" \
    | sed "s,@@sample_name@@,$sample_name,g" \
    | sbatch
done
 
echo 'Process complete : ' $(date) >> $LOG

