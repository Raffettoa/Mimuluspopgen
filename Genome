#8 6_run_mpileup.sh : requires bcftools, may have to install. This script creates the vcf files as an output

#!/bin/tcsh
#SBATCH --job-name=bcftools
#SBATCH -N 1
#SBATCH --ntasks-per-node 20
#SBATCH -t 72:00:00

module load miniforge3/24.9.2-0
conda activate mimulus

set BAMFILES="bamfiles.txt" # Each line in the file corresponds to a single BAM file.
set REF_FASTA="/sciclone/data10/akraffetto/mimulustest/Mcupreus_genome/Mimulus_cupreus_MCY43.PRELIM.mainGenome.fasta" # Indexed Ref FASTA
set THREADS=30
set OUT_DIR="6-MPILEUP"

# Remove -r line if bam files do not contain any alignments apart from the reference genome
# I had to do this because I initially aligned reads against the ref_genome+mito+chloroplast

bcftools mpileup -Ou \
  -f $REF_FASTA \
  -b $BAMFILES \
  -q 20 \
  -Q 20 \
  -a AD,DP,SP \
  --threads $THREADS \
| bcftools call -mv -Ou --threads $THREADS \
| bcftools view -Ou -m2 -M2 -v snps \
| bcftools norm -f $REF_FASTA -Oz -o $OUT_DIR/mimulus_snps.vcf.gz

