#2: 2_align_reads.sh : this requires the installation of bowtie2. What it does is take your samples and aligns them to the reference genome by mapping them to create a genome scaffold in order

#!/usr/bin/env bash
set -euo pipefail

## ----- Settings ----------------------------
NUM_CORES=6                                    		# Bowtie2 threads
MAIN="/sciclone/data10/akraffetto/mimulustest"
REF="$MAIN/1_genome_index/Mimulus_cupreus"      # Bowtie2 index basename (no extension)
FASTQ="$MAIN/fastq"                             	# Folder with R1/R2 fastq(.gz)
OUT="$MAIN/2-SAM-subset"                          	# Output SAM dir
LOG="$MAIN/Log_align_to_CDS.txt"                	# Log file
TEMPLATE=align_tmp.tcsh                         	# tcsh job template
## ----- End of settings ---------------------

mkdir -p "$OUT" "$(dirname "$LOG")"
echo "Starting : $(date)" > "$LOG"


for file in $FASTQ/*R1_001.fastq.gz; do
    start_time=$(date +%s)
    base=${file##*/}
    
    #####create a variable called R2 that is the filename of the r2 file corresponding to r1
    R2=${file%R1_001.fastq.gz}R2_001.fastq.gz
    ###END OF NEW CODE
        
    outfile=${base/.fastq.gz/.sam}
    outfile=${outfile/.fastq/.sam}
    outfile=$OUT/$outfile
    sample_name=$(basename "$file" "R1_001.fastq.gz")
    sample_name=$(echo "$sample_name" | cut -d"_" -f2)
    echo $sample_name

    
    ## Run bowtie
    cat align_tmp.tcsh \
    | sed "s,@@NUM_CORES@@,$NUM_CORES,g" \
    | sed "s,@@REF@@,$REF,g" \
    | sed "s,@@file@@,$file,g" \
    | sed "s,@@R2@@,$R2,g" \
    | sed "s,@@outfile@@,$outfile,g" \
    | sed "s,@@LOG@@,$LOG,g" \
    | sed "s,@@sample_name@@,$sample_name,g" \
    | sed "s,@@start_time@@,$start_time,g" \
    | sbatch
done

echo 'Process complete : ' $(date) >> $LOG

