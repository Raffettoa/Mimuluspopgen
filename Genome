#9 7_run_filters.sh : this filters out things like insertions and deletions, or things that are missing or where the quality is low. 

#!/bin/tcsh
#SBATCH --job-name=vcf_filters
#SBATCH -N 1
#SBATCH --ntasks-per-node 32
#SBATCH -t 48:00:00


module load miniforge3/24.9.2-0
conda activate mimulus

set INPUT_VCF="6-MPILEUP/mimulus_snps.vcf.gz"
set VCF_OUTPUT="7-VCF-OUTPUT"
mkdir -p $VCF_OUTPUT

set out1="1_remove_indels"
set out2="2_remove_missing"
set out3="3_remove_mdepth"
set out4="4_remove_genequal"
set out5="5_remove_indels2"
set out6="6_remove_maf"

echo "## Remove indels"
vcftools --gzvcf $INPUT_VCF --remove-indels --recode --recode-INFO-all --out $out1

echo "\n\t## Filter out sites with missing data"
# Exclude sites on the basis of the proportion of missing data
# (defined to be between 0 and 1, where 0 allows sites that are completely missing
# and 1 indicates no missing data allowed)
vcftools --vcf "$out1.recode.vcf" --max-missing 0.7 --recode --recode-INFO-all --out $out2

echo "\n\t## Filter minimum depth of coverage"
vcftools --vcf "$out2.recode.vcf" --min-meanDP 2 --recode --recode-INFO-all --out $out3

echo "\n\t## Filter out minimum Genotype Quality"
vcftools --vcf "$out3.recode.vcf" --minGQ 20 --recode --recode-INFO-all --out $out4

#echo "\n\t## Remove indels again"
#vcftools --vcf "$out4.recode.vcf" --remove-indels --recode --recode-INFO-all --out $out5

echo "\n\t## Remove minor allelic frequencies"
vcftools --vcf "$out4.recode.vcf" --maf 0.05 --recode --recode-INFO-all --out $out6

echo "\n\t## Done Filtering file: $INPUT_VCF"
echo "\n\t## Moving vcf files to: $VCF_OUTPUT"
mv *remove*.vcf "$VCF_OUTPUT/"

date

#10 8_run_plink.sh : takes your vcf files and analyzes the SNP's to create a pca output. Should be able to get to files, the eigenval and eigenvec, which you can then turn into a pca. 

#!/bin/tcsh
#SBATCH --job-name=runPLINK
#SBATCH -N 1
#SBATCH --ntasks-per-node 20
#SBATCH -t 48:00:00

module load miniforge3/24.9.2-0
conda activate mimulus

set PLINK_OUTPUT="8-PLINK-OUT"
mkdir -p $PLINK_OUTPUT

# Make BED file from vcf file: contains QTL data
echo "##\n\tMaking BED file "
plink --vcf 7-VCF-OUTPUT/6_remove_maf.recode.vcf --allow-extra-chr --chr-set 31 --make-bed --out qtl_out

# Run this if you are not getting any pca outputs: --mind 0.9 [removes samples with >90% missing genotypes]
echo "##\n\tRemove samples with missing genotypes "
plink --bfile qtl_out --mind 0.9 --make-bed --allow-extra-chr --chr-set 31 --out qtl_filtered

# Prune filtered dataset
echo "##\n\tPrune dataset "
plink --bfile qtl_filtered --indep-pairwise 50 10 0.1 --allow-extra-chr --chr-set 31 --out qtl_pruned

# Extract pruned SNPs
echo "##\n\tExtract pruned SNPs "
plink --bfile qtl_filtered --extract qtl_pruned.prune.in --allow-extra-chr --chr-set 31 --make-bed --out qtl_pruned2

# Run PCA
echo "##\n\tRun PCA "

plink --bfile qtl_pruned2 --pca 10 --allow-extra-chr --chr-set 31 --out qtl_pca

echo "##\n\tMoving all quantitative TL files to: $PLINK_OUTPUT"
mv qtl* $PLINK_OUTPUT


