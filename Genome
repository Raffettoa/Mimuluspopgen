#!/bin/env bash

MAIN="/sciclone/data10/akraffetto/mimulustest" 		# Make it easier. Work in the same directory as the other files.
INPUT_BAM="$MAIN/3-SAM-TO-BAM"			# Location of BAM files after containing only filtered reads that map
SORT_INDEX_DIR="$MAIN/3-SORT-AND-INDEX/1-SORT-INDEX" 	# Store index and sort files here
STATS="$MAIN/3-SORT-AND-INDEX/2-STATS" 			# Stats are stored here
THREADS=20						# This depends on the number of cores being used in the job

# Make sure these folders exist
mkdir -p $SORT_INDEX_DIR
mkdir -p $STATS


for sample in $INPUT_BAM/*.bam; do

	start_time=$(date +%s)
	name_prefix=$(basename "$sample")
	sorted_bam="$SORT_INDEX_DIR/$name_prefix"
	counts="$STATS/$name_prefix.txt"
	sample_name=$(basename "$file")

	cat alignment_stats.sh \
 	| sed "s,@@input_bam@@,$sample,g" \
	| sed "s,@@sorted_bam@@,$sorted_bam,g" \
	| sed "s,@@count_sorted@@,$counts,g" \
	| sed "s,@@sample_name@@,$sample_name,g" \
	| sed "s,@@threads@@,$THREADS,g" \
	| sbatch
Done

