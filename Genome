#!/bin/tcsh
#SBATCH --job-name=@@sample_name@@
#SBATCH -N 1
#SBATCH --ntasks-per-node 10
#SBATCH -t 48:00:00

module load miniforge3/24.9.2-0
conda activate mimulus

# Optional: derive NUM_CORES for tools that need -p
# Emmanuel: changed parameter from --very-sensitive-local to --fast-local

set start_time = `date +%s`
set file = @@file@@
set REF = @@REF@@
set R2 = @@R2@@
set outfile = @@outfile@@
set LOG = @@LOG@@

echo 'Current R1 file:\t\t' $file
echo 'Current R2 file:\t\t' $R2
echo 'Output will be:\t\t' $outfile

bowtie2 -p @@NUM_CORES@@ \
    --local --fast-local \
    -x $REF \
    -1 "$file" -2 "$R2" \
    -S "$outfile" \
    || echo "Something went wrong with file " $file >> $LOG


set end_time = `date +%s`
@ elapsed_time = $end_time - $start_time
@ hours = $elapsed_time / 3600
@ minutes = ( $elapsed_time % 3600 ) / 60
@ seconds = $elapsed_time % 60
echo "Script execution time: $hours hours, $minutes minutes, and $seconds seconds."

echo $file ' : ' `(date)` >> $LOG

